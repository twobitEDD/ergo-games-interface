      "resolved": "apps/web",
      "link": true
    },
    "packages/db": {
      "name": "@ergo-games/db",
      "version": "0.1.0"
    },
    "packages/domain": {
      "name": "@ergo-games/domain",
      "version": "0.1.0"
    },
